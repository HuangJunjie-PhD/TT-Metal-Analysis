    NOC_CHECK -->|"No"| NOC0["use_noc1=False"]
    
    NOC1 --> REMOTE_INIT
    NOC0 --> REMOTE_INIT
    NOC1 --> SIM_INIT
    NOC0 --> SIM_INIT
    NOC1 --> LOCAL_INIT
    NOC0 --> LOCAL_INIT


